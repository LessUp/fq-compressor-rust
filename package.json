{
  "name": "fq-compressor-rust-docs",
  "private": true,
  "version": "0.1.1",
  "description": "VitePress documentation for fq-compressor-rust",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs --port 5173",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 4173",
    "docs:clean": "rm -rf docs/.vitepress/dist",
    "docs:check": "vitepress build docs && echo 'Documentation build successful'"
  },
  "devDependencies": {
    "vitepress": "^1.0.0-rc.42",
    "vue": "^3.4.15"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
