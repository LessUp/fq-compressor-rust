{
  "name": "fq-compressor-rust-docs",
  "private": true,
  "version": "0.1.1",
  "description": "Documentation tooling for fq-compressor-rust",
  "scripts": {
    "docs:build": "honkit build docs/gitbook docs/.site",
    "docs:serve": "honkit serve docs/gitbook",
    "docs:pdf": "honkit pdf docs/gitbook docs/.site/fqc-rust.pdf",
    "docs:clean": "rm -rf docs/.site",
    "docs:check": "honkit build docs/gitbook docs/.site && echo 'Documentation build successful'"
  },
  "devDependencies": {
    "honkit": "^5.1.4",
    "gitbook-plugin-expandable-chapters": "^0.2.0",
    "gitbook-plugin-back-to-top-button": "^0.1.4",
    "gitbook-plugin-anchors": "^0.7.1",
    "gitbook-plugin-search-pro": "^2.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
